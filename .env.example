# Supabase (public, browser-safe values only — never the secret/service_role key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Demo-first: set to "false" to enable Supabase-backed accounts
NEXT_PUBLIC_DEMO_MODE=true

# Server-only keys (never exposed to the browser)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=
GITHUB_TOKEN=
